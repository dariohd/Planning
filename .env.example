# Base de données PostgreSQL (Neon, Vercel Postgres, Supabase, local...)
DATABASE_URL="postgresql://user:password@host:5432/planning?sslmode=require"

# NextAuth — générer avec : openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
# En local : http://localhost:3000  |  En prod : https://planning-black-xi.vercel.app
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Assistant Bulle (widget aide / FAQ)
NEXT_PUBLIC_BULLE_SITE_KEY="bulle_cb3598e0d1bc473049779cc01fa286378f441bff16eea879"

# Secret pour POST /api/admin/seed (header x-seed-secret) — optionnel, one-shot prod
SEED_SECRET=""

# Compte démo (identifiant + mot de passe, sans Google)
DEMO_USERNAME="demo"
DEMO_PASSWORD="change-me-demo-password"
# Administrateur pour compte de test partagé ; REAP si test du périmètre chef d'équipe
DEMO_USER_ROLE="Administrateur"
# Liaison optionnelle du compte démo à un collaborateur (permissions REAP ciblées)
# DEMO_PERSONNEL_ID="uuid-du-collaborateur"
# DEMO_PERSONNEL_NAME="Prénom Nom"
# DEMO_USER_EMAIL="demo@planning.local"

# Google OAuth (optionnel en dev)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Connexion dev locale (désactivée en production par défaut)
DEV_USER_EMAIL="admin@local.dev"
DEV_USER_ROLE="Administrateur"
ALLOW_DEV_LOGIN="true"

# Classeur ADECC pour mode Capa auto (optionnel, valeur par défaut intégrée)
# ADECC_SPREADSHEET_ID="1m_1QjM77r2GNAn6Utv9ExGk2yobKHayrHELJMI0h4Vk"

# Synchronisation Google Sheets (Paramètres > Données, activée par défaut)
# Désactiver l'UI liaison Sheets : NEXT_PUBLIC_SHEETS_SYNC="false"
# JSON du compte de service Google Cloud avec accès au classeur (optionnel si Web App GAS)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","client_email":"...","private_key":"..."}'

# Secret pour le cron de sync Sheets (header Authorization: Bearer <secret>)
# CRON_SECRET=""
